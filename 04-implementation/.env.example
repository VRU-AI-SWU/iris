# ── Model Server ──────────────────────────────────────────────────────────────
# Dev: LM Studio running on gpu-linux-server host
MODEL_SERVER_URL=http://host.docker.internal:1234/v1
# Prod: Ollama container (uncomment and set MODEL_SERVER_URL above to this)
# MODEL_SERVER_URL=http://ollama:11434/v1

EXTRACTION_MODEL=gemma-4-31b-it
EMBEDDING_MODEL=text-embedding-embeddinggemma-300m
# LM Studio uses a dummy key; Ollama also accepts any non-empty string
MODEL_API_KEY=lm-studio

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=iris
POSTGRES_PASSWORD=iris_dev_password
POSTGRES_DB=iris
DATABASE_URL=postgresql://iris:iris_dev_password@postgres:5432/iris

# ── Celery / Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Application ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DEBUG=true
LOG_LEVEL=INFO

# ── Scraping ──────────────────────────────────────────────────────────────────
# Delay between requests per domain (seconds)
SCRAPE_DELAY=2.0
# Max concurrent requests per domain
SCRAPE_CONCURRENCY=2
# Collection window (months) — postings older than this are ignored
JOB_POSTING_WINDOW_MONTHS=12
