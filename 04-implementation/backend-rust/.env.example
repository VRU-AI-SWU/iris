# ── Model Server ──────────────────────────────────────────────────────────────
MODEL_SERVER_URL=http://host.docker.internal:1234/v1
# Prod: MODEL_SERVER_URL=http://ollama:11434/v1

EXTRACTION_MODEL=gemma-4-e4b
EMBEDDING_MODEL=text-embedding-embeddinggemma-300m
MODEL_API_KEY=lm-studio

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://iris:iris_dev_password@postgres:5432/iris

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Application ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DEBUG=true
LOG_LEVEL=INFO

# ── Scraping ──────────────────────────────────────────────────────────────────
SCRAPE_DELAY=2.0
SCRAPE_CONCURRENCY=2
JOB_POSTING_WINDOW_MONTHS=12

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/data/tqf
REPORTS_DIR=/app/data/reports

# ── Python HDBSCAN sidecar ────────────────────────────────────────────────────
SIDECAR_URL=http://cluster-sidecar:8002
